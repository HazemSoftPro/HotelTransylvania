# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/hmsuite"

# JWT Tokens
NUXT_ACCESS_TOKEN="your-access-token-secret"
NUXT_ACCESS_TOKEN_EXP="15m"
NUXT_REFRESH_TOKEN="your-refresh-token-secret"
NUXT_REFRESH_TOKEN_EXP="7d"

# Sentry Configuration (Optional)
NUXT_PUBLIC_SENTRY_DSN=""
NUXT_PUBLIC_ENV="development"

# Application Settings
NODE_ENV="development"
NUXT_HOST="0.0.0.0"
NUXT_PORT="3000"
